# Landing app (marketing site) env.
# Copy to .env.local for local dev, and set the same vars on the landing
# deployment (e.g. Vercel landing project).

# Where the authed dashboard app lives. Used for cross-origin auth/dashboard
# links. Local dev: dashboard runs on :3000.
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# Clerk — MUST be the SAME instance the dashboard uses, so the shared session
# is readable here and the header toggles to "Dashboard" when signed in.
# clerkMiddleware (proxy.ts) needs the secret key; useAuth() needs the
# publishable key.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# IMPORTANT (production): cross-subdomain session sharing (apex url.com <->
# dashboard.url.com) only works with a Clerk PRODUCTION instance (pk_live_...).
# A development instance (pk_test_..., *.clerk.accounts.dev) only shares the
# session on localhost, so the signed-in "Dashboard" button will NOT appear on
# a real domain. Create a Clerk production instance for the apex domain and set
# pk_live_/sk_live_ keys on BOTH the landing and dashboard deployments.
