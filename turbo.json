{
    "$schema": "https://v2-9-7.turborepo.dev/schema.json",
    "globalDependencies": [".env"], // All task hashes
    "tasks": {
        "dev": {
            "persistent": true,
            "cache": false
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**"],
            "inputs": ["$TURBO_DEFAULT$", ".env"], // Only the `build` task hash
            // Env vars the Next.js builds need. NEXT_PUBLIC_* are inlined at
            // build time (dashboard URL, Clerk/Convex public keys); the server
            // vars below (Clerk secret, JWT issuer, Convex deploy) must be
            // passed through too or Vercel strips them — without the Clerk key
            // the landing header/hero can't detect the session.
            "env": [
                "NEXT_PUBLIC_*",
                "CLERK_SECRET_KEY",
                "CLERK_FRONTEND_API_URL",
                "CLERK_JWT_ISSUER_DOMAIN",
                "CONVEX_DEPLOYMENT",
                "CONVEX_DEPLOY_KEY"
            ]
        },
        "lint": {
            "dependsOn": ["^build"]
        },
        "type-check": {
            "dependsOn": ["^build"]
        }
    }
}
